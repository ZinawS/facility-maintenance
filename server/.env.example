# Copy to .env and fill in real values. Never commit the real .env file.

# --- Server ---
PORT=4000
NODE_ENV=development
# Absolute path for uploaded files. Leave unset for local dev (defaults to
# server/uploads). In production, point this OUTSIDE the deployed app
# directory so redeploys (fresh git clone, hPanel Git auto-deploy, rsync
# mirror, etc.) can't wipe previously uploaded files.
UPLOAD_DIR=

# --- Database (MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=facilitypro
DB_PORT=3306

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=1h

# --- Stripe ---
STRIPE_SECRET_KEY=
# Optional but required for payment status to update automatically; get this
# from the Stripe CLI (`stripe listen`) in development or the Stripe
# dashboard's webhook settings in production.
STRIPE_WEBHOOK_SECRET=

# --- Outbound email (password reset). Leave blank to log emails instead of sending. ---
NODEMAILER_EMAIL=
NODEMAILER_PASS=

# --- CORS / links ---
CLIENT_URL=http://localhost:5173
# Comma-separated list of allowed origins. Defaults to CLIENT_URL if unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
