# Used by `docker compose up` — copy to .env in this same directory.
# (This is separate from client/.env and server/.env, which are for running
# each app directly with `npm run dev` outside Docker.)

DB_PASSWORD=changeme
DB_NAME=facilitypro

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

NODEMAILER_EMAIL=
NODEMAILER_PASS=

# Public URL of the client container once deployed (used for CORS + email links).
CLIENT_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Baked into the client build at build time — must be reachable from the
# *browser*, not just from inside the Docker network.
VITE_API_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=
